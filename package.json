{
  "name": "prime-factorization",
  "version": "2026.7.10",
  "description": "A React app for computing prime factorizations and browsing small prime numbers.",
  "homepage": "https://doctorlai.github.io/prime-factorization",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest --watch=false",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "check": "npm run format && npm run lint && npm run coverage && npm run build",
    "ci": "npm run check",
    "clean": "rm -rf dist coverage",
    "badges:languages": "node scripts/update-language-badge.mjs",
    "deploy": "npm run add-version && npm run build && gh-pages -d dist",
    "add-version": "echo \"VITE_COMMIT_HASH=$(git rev-parse --short HEAD)\" > .env",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "gh-pages": "^6.3.0",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "vite": "^6.3.4",
    "vitest": "^3.1.2"
  }
}
